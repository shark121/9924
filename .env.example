# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin console login password (cookie session at /admin/login). Can be changed
# from the admin Settings page, which stores an override that takes precedence.
ADMIN_PASSWORD=adminpassword123

# Secret used to sign the admin session cookie. Recommended: a random 32+ byte
# value, e.g. `openssl rand -base64 32`. If unset, it's derived from
# ADMIN_PASSWORD so the console still works out of the box.
SESSION_SECRET=

# Optional: override where the SQLite database is stored. This single file now
# holds orders, products, and settings.
# ORDERS_DB_PATH=

# Google Maps Platform — Places autocomplete on the checkout address field.
# Enable "Places API" + billing, then restrict the key to your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Shippo — live shipping-rate quotes (server-only). Use a shippo_test_... token in dev.
SHIPPO_API_TOKEN=

# Ship-from origin (used for rate quotes). Defaults to a NYC address if unset.
SHIP_FROM_NAME=9924
SHIP_FROM_STREET1=
SHIP_FROM_CITY=New York
SHIP_FROM_STATE=NY
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=

# Flat international shipping price (USD). Domestic (SHIP_FROM_COUNTRY) ships
# free. Both are editable from the admin Settings page (DB override wins).
SHIP_INTL_FLAT_USD=30

# Optional parcel estimate overrides (kg / cm)
SHIP_ITEM_WEIGHT_KG=0.4
SHIP_PARCEL_L=33
SHIP_PARCEL_W=25
SHIP_PARCEL_H=6
