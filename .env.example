# Stripe
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Password for the order viewer at /admin/orders (HTTP Basic Auth; any username).
ADMIN_PASSWORD=

# Optional: override where the SQLite order database is stored.
# ORDERS_DB_PATH=

# Google Maps Platform — Places autocomplete on the checkout address field.
# Enable "Places API" + billing, then restrict the key to your domains.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Shippo — live shipping-rate quotes (server-only). Use a shippo_test_... token in dev.
SHIPPO_API_TOKEN=

# Ship-from origin (used for rate quotes). Defaults to a NYC address if unset.
SHIP_FROM_NAME=9924
SHIP_FROM_STREET1=
SHIP_FROM_CITY=New York
SHIP_FROM_STATE=NY
SHIP_FROM_ZIP=
SHIP_FROM_COUNTRY=US
SHIP_FROM_PHONE=

# Flat shipping price (USD) used when no carrier rates are found. Defaults to 15.
SHIP_FLAT_FALLBACK_USD=15

# Optional parcel estimate overrides (kg / cm)
SHIP_ITEM_WEIGHT_KG=0.4
SHIP_PARCEL_L=33
SHIP_PARCEL_W=25
SHIP_PARCEL_H=6
